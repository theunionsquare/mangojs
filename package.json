{
  "name": "mangojs",
  "version": "0.0.1",
  "private": true,
  "description": "MangoJS monorepo - Backend framework, documentation, and website",
  "repository": {
    "type": "git",
    "url": "https://github.com/theunionsquare/mangojs.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "pnpm --filter @theunionsquare/mangojs-core build",
    "build:docs": "pnpm --filter @@mangojs/docs build",
    "build:all": "pnpm build && pnpm build:docs",
    "dev": "pnpm --filter @theunionsquare/mangojs-core dev",
    "dev:docs": "pnpm --filter @@mangojs/docs start",
    "release": "node scripts/release.js",
    "clean": "rm -rf packages/*/dist packages/*/node_modules packages/*/.docusaurus packages/docs/build"
  },
  "keywords": [
    "nodejs",
    "backend",
    "framework",
    "microservices",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "release-it": "^19.0.5"
  }
}
