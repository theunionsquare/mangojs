{
  "name": "@theunionsquare/mangojs-core",
  "version": "0.1.1",
  "description": "A lightweight Node.js backend framework for microservices with code injection, Express API integration, and AI-driven development support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types/enums": {
      "import": "./dist/core/types/enums/index.js",
      "require": "./dist/core/types/enums/index.js",
      "types": "./dist/core/types/enums/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/theunionsquare/mangojs.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist/**/*",
    "handbook/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "nodejs",
    "backend",
    "framework",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=23.0.0"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.13.2",
    "bullmq": "^5.66.5",
    "console-table-printer": "^2.12.1",
    "cookie-parser": "^1.4.6",
    "cookie-session": "^2.0.0",
    "dotenv": "^16.1.4",
    "express": "^4.18.2",
    "inversify": "^7.10.6",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^5.9.2",
    "mongoose": "^8.19.1",
    "node-schedule": "^2.1.1",
    "openapi-types": "^12.1.3",
    "passport": "0.5",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9.1.0",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.26",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^24.3.0",
    "@types/node-schedule": "^2.1.8",
    "@types/passport": "^1.0.12",
    "@types/pino": "^7.0.5",
    "@types/swagger-ui-express": "^4.1.6",
    "typescript": "^5.3.0"
  }
}
