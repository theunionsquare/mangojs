# Server Configuration
PORT=3020
NODE_ENV=development

# Database Configuration (CockroachDB)
DATABASE_URL=postgresql://root@localhost:26257/subscription_db?sslmode=disable
DB_NAME=subscription_db

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3080,http://localhost:3090

# Authentication Service
IAM_SERVICE_URL=http://localhost:3010

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_RETURN_URL=http://localhost:3020/api/subscription/v1/payments/paypal/success
PAYPAL_CANCEL_URL=http://localhost:3020/api/subscription/v1/payments/paypal/cancel

# Logging
LOG_LEVEL=debug

# Business Configuration
DEFAULT_CURRENCY=USD
DEFAULT_TRIAL_DAYS=14

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Webhook URLs
SUBSCRIPTION_WEBHOOK_URL=http://localhost:3020/api/subscription/v1/webhooks
PAYMENT_SUCCESS_URL=http://localhost:3080/subscription/success
PAYMENT_CANCEL_URL=http://localhost:3080/subscription/cancel

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600