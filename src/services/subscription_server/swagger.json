{
    "swaggerDefinition": {
        "openapi": "3.0.0",
        "info": {
            "title": "Subscription Server",
            "version": "1.0.0",
            "description": "Service-based subscription management API"
        },
        "servers": [
            {
                "url": "http://localhost:3020",
                "description": "subscription server address"
            }
        ],
        "components": {
            "securitySchemes": {
                "cookieAuth": {
                    "type": "apiKey",
                    "in": "cookie",
                    "name": "session"
                },
                "adminAuth": {
                    "type": "apiKey",
                    "in": "cookie",
                    "name": "admin_session"
                }
            }
        }
    },
    "apis": ["**/src/routes/**/*.ts"]
}